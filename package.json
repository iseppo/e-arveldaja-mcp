{
  "name": "e-arveldaja-mcp",
  "version": "0.3.2",
  "description": "MCP server for Estonian e-arveldaja (e-Financials) API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "e-arveldaja-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "workflows/",
    ".claude/commands/",
    "LICENSE",
    "README.md",
    "CLAUDE.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "e-arveldaja",
    "e-financials",
    "estonia",
    "accounting",
    "invoicing",
    "rik"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/iseppo/e-arveldaja-mcp.git"
  },
  "license": "Unlicense",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.7",
    "fastest-levenshtein": "^1.0.16",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
