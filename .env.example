# e-arveldaja API credentials
EARVELDAJA_API_KEY_ID=your_api_key_id
EARVELDAJA_API_PUBLIC_VALUE=your_base64_public_value
EARVELDAJA_API_PASSWORD=your_password

# API server: "live" or "demo"
EARVELDAJA_SERVER=live

# Optional file-access hardening. By default, file-reading tools can read
# supported documents anywhere under your home directory and /tmp.
# Use a colon-separated allowlist to restrict reads to specific folders.
# EARVELDAJA_ALLOWED_PATHS=/path/to/arved:/tmp

# Optional LiteParse OCR settings.
# OCR runs locally by default. If you set EARVELDAJA_LITEPARSE_OCR_SERVER_URL,
# invoice documents will be sent to that OCR server. Remote OCR endpoints must
# use https. Plain http is only allowed for localhost / loopback OCR services.
# EARVELDAJA_LITEPARSE_OCR_ENABLED=true
# EARVELDAJA_LITEPARSE_OCR_LANGUAGE=eng+est
# EARVELDAJA_LITEPARSE_OCR_SERVER_URL=
